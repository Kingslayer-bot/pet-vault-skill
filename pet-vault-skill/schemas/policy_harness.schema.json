{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PetVault Policy Harness",
  "type": "object",
  "required": ["policy_id", "pet_id", "insurer", "jurisdiction", "raw_policy_material_id", "extraction_confidence", "needs_manual_review"],
  "properties": {
    "policy_id": {"type": "string"},
    "pet_id": {"type": "string"},
    "insurer": {"type": "string"},
    "product_name": {"type": ["string", "null"]},
    "jurisdiction": {"type": "string"},
    "policy_start_date": {"type": ["string", "null"]},
    "policy_end_date": {"type": ["string", "null"]},
    "waiting_period": {"type": ["string", "null"]},
    "deductible": {"type": ["number", "null"]},
    "deductible_type": {"enum": ["annual", "per_condition", "per_claim", "unknown"]},
    "reimbursement_rate": {"type": ["number", "null"]},
    "annual_limit": {"type": ["number", "null"]},
    "per_item_limits": {"type": "array", "items": {"type": "object"}},
    "excluded_conditions": {"type": "array", "items": {"type": "string"}},
    "pre_existing_definition": {"type": ["string", "null"]},
    "wellness_addon": {"type": ["boolean", "null"]},
    "network_requirement": {"type": ["string", "null"]},
    "required_documents": {"type": "array", "items": {"type": "string"}},
    "raw_policy_material_id": {"type": "string"},
    "extraction_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "needs_manual_review": {"type": "boolean"}
  }
}
