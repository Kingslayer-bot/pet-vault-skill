{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PetVault Pet Profile",
  "type": "object",
  "required": ["pet_id", "name", "species", "created_at", "updated_at"],
  "properties": {
    "pet_id": {"type": "string"},
    "name": {"type": "string"},
    "species": {"enum": ["dog", "cat", "other", "unknown"]},
    "breed": {"type": ["string", "null"]},
    "sex": {"enum": ["male", "female", "unknown"]},
    "neutered": {"type": ["boolean", "null"]},
    "birth_date": {"type": ["string", "null"]},
    "weight_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "weight"],
        "properties": {
          "date": {"type": "string"},
          "weight": {"type": "number"},
          "unit": {"enum": ["kg", "lb"]}
        }
      }
    },
    "known_conditions": {"type": "array", "items": {"type": "string"}},
    "allergies": {"type": "array", "items": {"type": "string"}},
    "microchip_id": {"type": ["string", "null"]},
    "owner_notes": {"type": ["string", "null"]},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  }
}
