{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PetVault Material",
  "type": "object",
  "required": ["material_id", "material_type", "source_file", "language", "jurisdiction", "confidence"],
  "properties": {
    "material_id": {"type": "string"},
    "pet_id": {"type": ["string", "null"]},
    "material_type": {
      "enum": ["invoice", "payment_record", "medical_record", "lab_report", "imaging_report", "insurance_policy", "claim_form", "rejection_letter", "chat_record", "prescription", "unknown"]
    },
    "source_file": {"type": "string"},
    "ocr_text": {"type": ["string", "null"]},
    "language": {"type": "string"},
    "currency": {"type": ["string", "null"]},
    "jurisdiction": {"type": "string"},
    "date_detected": {"type": ["string", "null"]},
    "clinic_name": {"type": ["string", "null"]},
    "insurance_company": {"type": ["string", "null"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
