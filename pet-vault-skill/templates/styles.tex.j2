\linespread{1.28}
\setlist[itemize]{leftmargin=2.2em,itemsep=2pt,topsep=4pt}
\setlist[enumerate]{leftmargin=2.5em,itemsep=2pt,topsep=4pt}
\captionsetup{font=small,labelsep=quad}
